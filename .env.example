# Gmail API OAuth 2.0 Credentials
# Get these from Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here

# Optional: Path to store OAuth tokens (defaults to credentials/token.json)
# TOKEN_PATH=credentials/token.json

# Module 2 – optional vanilla Playwright login (do not commit real values)
# Prefer CDP or persistent Chromium profile when possible; 2FA/CAPTCHA may block automation.
# JOBO_LINKEDIN_EMAIL=
# JOBO_LINKEDIN_PASSWORD=

# Module 2 – Playwright (optional; see docs/module2_implementation.md)
# JOBO_PLAYWRIGHT_CDP_URL=http://127.0.0.1:9222
# JOBO_PLAYWRIGHT_USER_DATA_DIR=/path/to/chromium-profile
# JOBO_PLAYWRIGHT_HEADLESS=0
# JOBO_ENRICH_DELAY_MS_MAX=2500 optional max jitter between job URLs (ms)

# Module 2 – Ollama (local LLM)
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# Module 3 – Gemini / jobo triage (see docs/module3_overview.md)
# GEMINI_API_KEY=   # https://aistudio.google.com/app/apikey
# JOBO_GEMINI_MODEL=gemini-2.0-flash
# JOBO_MIN_FIT_SCORE=3
# JOBO_PROFILE_CONTEXT_PATH=module3/context/profile.md
# JOBO_BASE_RESUME_TEX=/path/to/base_resume.tex
# JOBO_DEFAULT_RESUME_PDF=/path/to/base_resume.pdf
# JOBO_ARTIFACTS_DIR=data/module3/artifacts
